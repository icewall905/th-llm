# Copy this file to .env and fill in your values.

# URL of your OpenAI-compatible LLM API (llama.cpp, Ollama, vLLM, OpenAI, etc.)
LLM_BASE_URL=http://localhost:8080/v1

# Leave blank to auto-detect the first model returned by /v1/models
LLM_MODEL=

# API key — use "none" for local servers that don't require auth
LLM_API_KEY=none

# Default blind structure and starting stacks (can also be set per room in the UI)
SMALL_BLIND=10
BIG_BLIND=20
STARTING_STACK=1000
